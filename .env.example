# MongoDB
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_DB=truthfeed

# BERT Model
MODEL_SOURCE=huggingface
HUGGINGFACE_MODEL_PATH=avivaaaaa123/fake-news-detector
MAX_LENGTH=128

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-a-random-256-bit-hex-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# NewsAPI — get key from https://newsapi.org
NEWS_API_KEY=<your-newsapi-key>

# App
ENVIRONMENT=local
CONFIDENCE_THRESHOLD=0.5
DOWNVOTE_RECHECK_THRESHOLD=10
FRONTEND_URL=http://localhost:3000

# Admin — this email gets auto-admin role on signup
ADMIN_EMAIL=your-admin@email.com
